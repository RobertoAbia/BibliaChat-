# =============================================================================
# BIBLIA CHAT - Environment Variables
# =============================================================================
# Copia este archivo a .env y completa los valores
# NUNCA commitees el archivo .env con secretos reales
# =============================================================================

# =============================================================================
# Supabase
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key

# =============================================================================
# RevenueCat
# =============================================================================
REVENUECAT_API_KEY_IOS=your-ios-key
REVENUECAT_API_KEY_ANDROID=your-android-key
REVENUECAT_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# Firebase (for FCM)
# =============================================================================
# Las credenciales de Firebase se manejan via google-services.json (Android)
# y GoogleService-Info.plist (iOS), no aquí.

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
# Valores: development | staging | production
